{
  "expo": {
    "name": "Family App",
    "slug": "family-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0f13"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourfamily.app"
    },
    "android": {
      "package": "com.yourfamily.app"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "familyapp",
    "experiments": {
      "typedRoutes": true
    }
  }
}